{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "env": [
    {
      "key": "VITE_API_URL",
      "description": "Backend API URL for Socket.io connections",
      "required": true
    }
  ]
}
