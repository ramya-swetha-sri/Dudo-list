# Backend API Configuration

# Database
DATABASE_URL=postgresql://user:password@host:port/database

# JWT Secret for authentication
JWT_SECRET=your-super-secret-key-change-this-in-production

# Server Port
PORT=3000

# Frontend URL for CORS and Socket.io connections
# For development: http://localhost:5173
# For production (Vercel): https://your-frontend-vercel-url.vercel.app
FRONTEND_URL=http://localhost:5173

# Optional: Node environment
NODE_ENV=development

# Email Configuration (Optional - for sending friend request emails)
# Leave EMAIL_USER and EMAIL_PASSWORD empty to skip email notifications
# When empty, emails will be logged to console in test mode

# Email service provider settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false

# Gmail configuration:
# 1. Generate an App Password: https://support.google.com/accounts/answer/185833
# 2. Set EMAIL_USER to your Gmail address
# 3. Set EMAIL_PASSWORD to your App Password
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password-here
